  cat <<EOF
Usage:
  kite feature [target-directory] [--json]

One-screen status view for the active Speckit feature.

Shows:
  - Feature name, branch, and current lifecycle stage
  - Checklist of canonical artifacts (done vs pending)
  - Last 3 artifacts changed (by modification time)
  - Single recommended next action

The active feature is detected from .specify/feature.json, the current
git branch, or a sole directory under specs/.

Options:
  --json             Emit machine-readable JSON for tooling

Examples:
  kite feature
  kite feature --json
EOF
}

explain_help() {
  cat <<EOF
Usage:
  kite explain <stage>

Plain-language description of a Speckit workflow stage.

Designed for non-technical users and junior engineers. Each stage
shows: what happens, who runs it, what artifact it produces, and
what to do next.

Default lifecycle:
  feature start -> discover -> constitution -> specify -> design -> plan -> tasks -> analyze -> implement -> test -> review -> verify -> release

Stages:
  discover     Idea and audience exploration (Strategist)
  constitution Project standards and non-negotiables
  specify      Requirements and acceptance criteria
  design       Visual direction and design system
  plan         Technical plan and architecture
  tasks        Task breakdown with IDs
  analyze      Consistency and coverage analysis
  implement    Backend + UI implementation
  test         Automated and manual verification
  review       Code review synthesis
  verify       Pre-merge checklist (kite verify feature)
  release      Version bump, tag, deploy
  operate      Monitoring, logging, alerts
  learn        Post-release feedback capture

Examples:
  kite explain discover
  kite explain plan
EOF
}


show_help() {
  case "$1" in
    "install-speckit")
      install_speckit_help
      ;;
    "update-workspace")
      update_workspace_help
      ;;
    "doctor")
      doctor_help
      ;;
    "status")
      status_help
      ;;
    "test")
      test_help
      ;;
    "audit")
      audit_help
      ;;
    "release")
      release_help
      ;;
    "verify-feature")
      verify_feature_help
      ;;
    "feature")
      feature_help
      ;;
    "explain")
      explain_help
      ;;
    *)
      general_help
      ;;
  esac
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

shell_join() {
  local arg quoted output=""

  for arg in "$@"; do
    printf -v quoted '%q' "$arg"
    if [[ -n "$output" ]]; then
      output+=" "
    fi
    output+="$quoted"
  done

  printf '%s\n' "$output"
}

json_escape() {
  local value="$1"

  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}

  printf '"%s"' "$value"
}

json_array() {
  local first=1 item

  printf '['
  for item in "$@"; do
    if [[ $first -eq 0 ]]; then
      printf ','
    fi
    json_escape "$item"
    first=0
  done
  printf ']'
}

find_extracted_source_root() {
  local devcontainer_dir extracted_root

  devcontainer_dir="$(find "$temp_dir" -mindepth 2 -maxdepth 4 -type d -name .devcontainer | head -n 1 || true)"
  if [[ -n "$devcontainer_dir" ]]; then
    dirname "$devcontainer_dir"
    return
  fi

  extracted_root="$(find "$temp_dir" -mindepth 1 -maxdepth 1 -type d | head -n 1 || true)"
  if [[ -z "$extracted_root" ]]; then
    echo "Failed to locate source root in downloaded archive." >&2
    exit 1
  fi

  printf '%s\n' "$extracted_root"
}

resolve_source_root() {
  if [[ -n "$source_root" ]]; then
    printf '%s\n' "$source_root"
    return
  fi

  if [[ -n "$source_dir" ]]; then
    if ! source_root="$(cd -- "$source_dir" 2>/dev/null && pwd)"; then
      echo "Source directory does not exist: $source_dir" >&2
      exit 1
    fi

    printf '%s\n' "$source_root"
    return
  fi

  require_command curl
  require_command tar
  require_command mktemp

  temp_dir="$(mktemp -d)"
  local archive_path="$temp_dir/dev-env.tar.gz"
  local archive_url="https://github.com/${repo}/archive/${ref}.tar.gz"

  curl -fsSL "$archive_url" -o "$archive_path"
  tar -xzf "$archive_path" -C "$temp_dir"
  source_root="$(find_extracted_source_root)"
  printf '%s\n' "$source_root"
}

has_speckit_bootstrap() {
  local target="$1"
  local required_file
  local required_files=(
    .specify/presets/orchestrator-workflow/preset.yml
    .specify/presets/orchestrator-workflow/commands/speckit.discover.md
    .specify/presets/orchestrator-workflow/commands/speckit.constitution.md
    .specify/presets/orchestrator-workflow/commands/speckit.design.md
    .specify/presets/orchestrator-workflow/commands/speckit.plan.md
    .specify/presets/orchestrator-workflow/commands/speckit.implement.md
    .specify/presets/orchestrator-workflow/commands/speckit.implement.backend.md
    .specify/presets/orchestrator-workflow/commands/speckit.implement.ui.md
    .specify/presets/orchestrator-workflow/commands/speckit.test.md
    .specify/workflows/orchestrator-design-first/workflow.yml
    .github/agents/speckit.constitution.agent.md
    .github/agents/speckit.design.agent.md
    .github/agents/speckit.implement.agent.md
  )

  for required_file in "${required_files[@]}"; do
    if [[ ! -f "$target/$required_file" ]]; then
      return 1
    fi
  done

  return 0
}

devcontainer_brownfield_contract_files_present() {
  local target_path="$1"
  local required_path
  local required_paths=(
    devcontainer.json
    bin/kite
    kite-post-create.sh
    README.kite.md
  )

  for required_path in "${required_paths[@]}"; do
    if [[ ! -e "$target_path/$required_path" ]]; then
      return 1
    fi
  done

  return 0
}

devcontainer_brownfield_contract_matches_source() {
  local source_path="$1"
  local target_path="$2"

  devcontainer_brownfield_contract_files_present "$target_path" || return 1

  diff -q "$source_path/bin/kite" "$target_path/bin/kite" >/dev/null 2>&1 || return 1
  diff -q "$source_path/post-create.sh" "$target_path/kite-post-create.sh" >/dev/null 2>&1 || return 1
  diff -q "$source_path/README.md" "$target_path/README.kite.md" >/dev/null 2>&1 || return 1

  return 0
}

merge_missing_tree_contract_matches_source() {
  local source_path="$1"
  local target_path="$2"
  local source_entry rel_path

  while IFS= read -r -d '' source_entry; do
    rel_path="${source_entry#"$source_path"/}"
    if [[ ! -e "$target_path/$rel_path" ]]; then
      return 1
    fi
  done < <(find "$source_path" -mindepth 1 -print0)

  return 0
}

asset_matches_source() {
  local asset="$1"
  local source_path="$2"
  local target_path="$3"

  case "$asset" in
    .devcontainer)
      if diff -qr "$source_path" "$target_path" >/dev/null 2>&1; then
        return 0
      fi
      devcontainer_brownfield_contract_matches_source "$source_path" "$target_path"
      return
      ;;
    .github/prompts|.github/agents|.github/instructions|docs/errors)
      merge_missing_tree_contract_matches_source "$source_path" "$target_path"
      return
      ;;
    .github/copilot-instructions.md)
      [[ -f "$target_path" ]]
      return
      ;;
    .github/agents)
      diff -qr --exclude='speckit.*.agent.md' "$source_path" "$target_path" >/dev/null 2>&1
      ;;
    .github/prompts)
      diff -qr --exclude='speckit.*.prompt.md' "$source_path" "$target_path" >/dev/null 2>&1
      ;;
    *)
      # File-level asset: use diff -q (not -r)
      if [[ -f "$source_path" ]]; then
        diff -q "$source_path" "$target_path" >/dev/null 2>&1
        return
      fi
      diff -qr "$source_path" "$target_path" >/dev/null 2>&1
      ;;
  esac
}

collect_asset_state() {
  local resolved_source="$1"
  local asset

  # Reload assets from manifest if available
  local -a manifest_assets=()
  while IFS= read -r line; do
    manifest_assets+=("$line")
  done < <(load_asset_manifest "$resolved_source/.dev-env-assets")
  if [[ ${#manifest_assets[@]} -gt 0 ]]; then
    assets=("${manifest_assets[@]}")
  fi

  ASSET_CURRENT=()
  ASSET_MISSING=()
  ASSET_OUTDATED=()

  for asset in "${assets[@]}"; do
    if [[ ! -e "$target_dir/$asset" ]]; then
      ASSET_MISSING+=("$asset")
    elif asset_matches_source "$asset" "$resolved_source/$asset" "$target_dir/$asset"; then
      ASSET_CURRENT+=("$asset")
    else
      ASSET_OUTDATED+=("$asset")
    fi
  done
}

target_arg() {
  if [[ "$target_dir" == "$PWD" ]]; then
    printf '.\n'
    return
  fi

  printf '%s\n' "$target_dir"
}

build_kite_command() {
  local -a cmd=(kite)
  local target

  cmd+=("$@")

  if [[ -n "$speckit_version" ]]; then
    cmd+=(--speckit-version "$speckit_version")
  fi

  if [[ -n "$source_dir" ]]; then
    cmd+=(--source-dir "$source_dir")
  else
    if [[ "$repo" != "$default_repo" ]]; then
      cmd+=(--repo "$repo")
    fi
    if [[ "$ref" != "$default_ref" ]]; then
      cmd+=(--ref "$ref")
    fi
  fi

  target="$(target_arg)"
  cmd+=("$target")
  shell_join "${cmd[@]}"
}

build_post_create_command() {
  local script_path="$target_dir/.devcontainer/post-create.sh"

  if [[ -f "$target_dir/.devcontainer/kite-post-create.sh" ]]; then
    script_path="$target_dir/.devcontainer/kite-post-create.sh"
  fi

  if [[ "$target_dir" == "$PWD" ]]; then
    script_path=".devcontainer/post-create.sh"
    if [[ -f "$target_dir/.devcontainer/kite-post-create.sh" ]]; then
      script_path=".devcontainer/kite-post-create.sh"
    fi
  fi

  shell_join bash "$script_path"
}

default_branch_name() {
  local target="${1:-.}"
  local branch
  branch="$(git -C "$target" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's#refs/remotes/origin/##' || true)"
  if [[ -z "$branch" ]]; then
    branch="main"
  fi
  printf '%s\n' "$branch"
}

is_interactive_terminal() {
  [[ -t 0 && -t 1 ]]
}

validate_choice() {
  local field="$1"
  local value="$2"
  shift 2

  local allowed
  for allowed in "$@"; do
    if [[ "$value" == "$allowed" ]]; then
      return 0
    fi
  done

  echo "Unsupported $field: $value" >&2
  echo "Allowed values: $*" >&2
  return 1
}

prompt_choice() {
  local result_var="$1"
  local prompt="$2"
  local default_value="$3"
  shift 3

  local -a options=("$@")
  local option_count="${#options[@]}"
  local default_index=1
  local idx=1
  local option_spec value label description answer

  if ! is_interactive_terminal; then
    printf -v "$result_var" '%s' "$default_value"
    return 0
  fi

  echo "$prompt"
  for option_spec in "${options[@]}"; do
    IFS='|' read -r value label description <<< "$option_spec"
    if [[ "$value" == "$default_value" ]]; then
      default_index=$idx
    fi
    printf '  %d) %s' "$idx" "$label"
    if [[ -n "$description" ]]; then
      printf ' - %s' "$description"
    fi
    if [[ "$value" == "$default_value" ]]; then
      printf ' [recommended]'
    fi
    printf '\n'
    idx=$((idx + 1))
  done

  while true; do
    printf 'Choose 1-%d [%d]: ' "$option_count" "$default_index"
    IFS= read -r answer || answer=""
    if [[ -z "$answer" ]]; then
      answer="$default_index"
    fi
    if [[ "$answer" =~ ^[0-9]+$ ]] && (( answer >= 1 && answer <= option_count )); then
      IFS='|' read -r value _ <<< "${options[$((answer - 1))]}"
      printf -v "$result_var" '%s' "$value"
      echo ""
      return 0
    fi
    echo "Enter a number between 1 and $option_count."
  done
}

write_kite_config() {
  local target="$1"
  local license="$2"
  local deploy_target="$3"
  local test_tier="$4"

  mkdir -p "$target/.kite"
  cat > "$target/.kite/config.yml" <<EOF
# Repo-local defaults for the kite workflow.
schema_version: 1

scaffold:
  template: base
  license: $license

workflow:
  test_tier: $test_tier

deploy:
  target: $deploy_target
EOF
}

suggest_feature_branch_name() {
  local feature_dir feature_name="my-feature"
  feature_dir="$(get_active_feature_dir "$target_dir" 2>/dev/null || true)"
  if [[ -n "$feature_dir" ]]; then
    feature_name="$(basename "$feature_dir")"
  fi
  feature_name="$(printf '%s' "$feature_name" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-')"
  feature_name="${feature_name#-}"
  feature_name="${feature_name%-}"
  if [[ -z "$feature_name" ]]; then
    feature_name="my-feature"
  fi
  printf 'feat/%s\n' "$feature_name"
}

error_doc_path() {
  local doc_name="$1"
  local doc_path="$target_dir/docs/errors/$doc_name"
  if [[ "$target_dir" == "$PWD" ]]; then
    doc_path="docs/errors/$doc_name"
  fi
  printf '%s\n' "$doc_path"
}

print_recovery_block() {
  local explanation="$1"
  local doc_path="$2"
  shift 2

  echo "       Why: $explanation"
  if [[ $# -gt 0 ]]; then
    echo "       Try next:"
    local step
    for step in "$@"; do
      echo "         $step"
    done
  fi
  if [[ -n "$doc_path" ]]; then
    echo "       Learn more: $doc_path"
  fi
}

detect_stack() {
  local target="$1"
  local has_python=0
  local has_typescript=0

  if [[ -f "$target/pyproject.toml" ]] || [[ -f "$target/setup.py" ]] || [[ -f "$target/setup.cfg" ]] || [[ -f "$target/requirements.txt" ]] || [[ -f "$target/Pipfile" ]]; then
    has_python=1
  fi

  if [[ -f "$target/package.json" ]] || [[ -f "$target/tsconfig.json" ]] || [[ -f "$target/pnpm-lock.yaml" ]] || [[ -f "$target/yarn.lock" ]]; then
    has_typescript=1
  fi

  if [[ $has_python -eq 1 && $has_typescript -eq 1 ]]; then
    printf 'fullstack\n'
  elif [[ $has_python -eq 1 ]]; then
    printf 'python\n'
  elif [[ $has_typescript -eq 1 ]]; then
    printf 'typescript\n'
  else
    printf 'unknown\n'
  fi
}

read_kite_test_profile() {
  local config_file="$1/.kite/config.yml"
  local configured_value=""

  if [[ -f "$config_file" ]]; then
    configured_value="$(awk '
      /^[[:space:]]*workflow:[[:space:]]*$/ { in_workflow = 1; next }
      in_workflow && /^[^[:space:]]/ { in_workflow = 0 }
      in_workflow && /^[[:space:]]*test_tier:[[:space:]]*/ {
        sub(/^[[:space:]]*test_tier:[[:space:]]*/, "", $0)
        gsub(/["'"'"'[:space:]]/, "", $0)
        print $0
        exit
      }
    ' "$config_file")"
  fi

  if [[ -n "$configured_value" ]]; then
    printf '%s\n' "$configured_value"
  else
    printf 'standard\n'
  fi
}

expand_test_profile() {
  case "$1" in
    smoke)
      printf 'unit\n'
      ;;
    standard)
      printf 'unit\nintegration\n'
      ;;
    full|all)
      printf 'unit\nintegration\ne2e\na11y\nperf\nsecurity\n'
      ;;
    unit|integration|e2e|a11y|perf|security)
      printf '%s\n' "$1"
      ;;
    *)
      return 1
      ;;
  esac
}

project_has_manifest() {
  local target="$1"

  [[ -d "$target" ]] || return 1
  [[ -f "$target/package.json" || -f "$target/pyproject.toml" || -f "$target/setup.py" || -f "$target/setup.cfg" || -f "$target/requirements.txt" || -f "$target/Pipfile" ]]
}

discover_workspace_patterns() {
  local target="$1"

  if [[ -f "$target/package.json" ]]; then
    if command -v jq >/dev/null 2>&1; then
      jq -r 'if (.workspaces | type) == "array" then .workspaces[] elif (.workspaces.packages | type) == "array" then .workspaces.packages[] else empty end' "$target/package.json" 2>/dev/null || true
    else
      node -e 'try { const pkg = require(process.argv[1]); const workspaces = Array.isArray(pkg.workspaces) ? pkg.workspaces : (pkg.workspaces && Array.isArray(pkg.workspaces.packages) ? pkg.workspaces.packages : []); for (const pattern of workspaces) console.log(pattern); } catch (error) {}' "$target/package.json" 2>/dev/null || true
    fi
  fi

  if [[ -f "$target/pnpm-workspace.yaml" ]]; then
    awk '
      /^[[:space:]]*packages:[[:space:]]*$/ { in_packages = 1; next }
      in_packages && /^[^[:space:]-]/ { in_packages = 0 }
      in_packages && /^[[:space:]]*-[[:space:]]*/ {
        sub(/^[[:space:]]*-[[:space:]]*/, "", $0)
        gsub(/["'"'"']/, "", $0)
        print $0
      }
    ' "$target/pnpm-workspace.yaml"
  fi
}

discover_project_roots() {
  local target="$1"
  local -a roots=()
  local candidate
  local pattern
  local canonical_candidate
  local -A seen=()

  add_project_root() {
    local candidate_path="$1"

    project_has_manifest "$candidate_path" || return 0
    canonical_candidate="$(cd "$candidate_path" 2>/dev/null && pwd -P)" || return 0
    if [[ -z "${seen[$canonical_candidate]:-}" ]]; then
      roots+=("$canonical_candidate")
      seen["$canonical_candidate"]=1
    fi
  }

  add_project_root "$target"

  for candidate in "$target"/backend "$target"/api "$target"/server "$target"/frontend "$target"/web "$target"/app "$target"/apps/* "$target"/services/* "$target"/libs/* "$target"/packages/*; do
    add_project_root "$candidate"
  done

  while IFS= read -r pattern; do
    [[ -n "$pattern" ]] || continue
    while IFS= read -r candidate; do
      add_project_root "$candidate"
    done < <(compgen -G "$target/$pattern" || true)
  done < <(discover_workspace_patterns "$target")

  if [[ ${#roots[@]} -eq 0 ]]; then
    roots=("$target")
  fi

  printf '%s\n' "${roots[@]}"
}

python_tests_exist() {
  local project_root="$1"

  [[ -f "$project_root/pytest.ini" || -f "$project_root/pyproject.toml" || -f "$project_root/setup.cfg" ]] \
    || find "$project_root" -maxdepth 3 \( -name 'test_*.py' -o -name '*_test.py' \) -print -quit 2>/dev/null | grep -q .
}

first_existing_path() {
  local candidate

  for candidate in "$@"; do
    if [[ -e "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

first_glob_match() {
  local pattern
  local match

  for pattern in "$@"; do
    match="$(compgen -G "$pattern" | head -n 1 || true)"
    if [[ -n "$match" ]]; then
      printf '%s\n' "$match"
      return 0
    fi
  done

  return 1
}

package_has_script() {
  local project_root="$1"
  local script_name="$2"

  [[ -f "$project_root/package.json" ]] || return 1

  if command -v jq >/dev/null 2>&1; then
    jq -e --arg script_name "$script_name" '.scripts[$script_name] != null' "$project_root/package.json" >/dev/null 2>&1
  else
    node -e 'try { const pkg = require(process.argv[1]); process.exit(pkg.scripts && Object.prototype.hasOwnProperty.call(pkg.scripts, process.argv[2]) ? 0 : 1); } catch (error) { process.exit(1); }' "$project_root/package.json" "$script_name" >/dev/null 2>&1
  fi
}

run_package_script() {
  local project_root="$1"
  local script_name="$2"

  if command -v pnpm >/dev/null 2>&1 && [[ -f "$project_root/pnpm-lock.yaml" ]]; then
    (cd "$project_root" && pnpm run "$script_name")
  elif command -v npm >/dev/null 2>&1; then
    (cd "$project_root" && npm run "$script_name")
  else
    echo "[warn] No Node.js package runner found for $script_name" >&2
    return 1
  fi
}

run_python_pytest() {
  local project_root="$1"
  shift

  if command -v uv >/dev/null 2>&1; then
    (cd "$project_root" && uv run pytest -v "$@")
  elif [[ -f "$project_root/.venv/bin/pytest" ]]; then
    (cd "$project_root" && .venv/bin/pytest -v "$@")
  elif command -v pytest >/dev/null 2>&1; then
    (cd "$project_root" && pytest -v "$@")
  else
    echo "[warn] No Python test runner found (pytest). Install with: uv add --dev pytest"
    return 1
  fi
}

make_target_exists() {
  local project_root="$1"
  local target_name="$2"

  [[ -f "$project_root/Makefile" ]] && grep -Eq "^${target_name}:" "$project_root/Makefile"
}

run_test_tier_for_root() {
  local tier="$1"
  local project_root="$2"
  local stack="$3"
  local result_var="$4"
  local ran=0
  local config_path=""
  local test_path=""

  printf -v "$result_var" '%s' 0

  case "$tier" in
    unit)
      case "$stack" in
        python|fullstack)
          if python_tests_exist "$project_root"; then
            ran=1
            echo "Running Python unit tests..."
            run_python_pytest "$project_root" || return 1
          fi
          ;;&
        typescript|fullstack)
          if [[ -f "$project_root/package.json" ]]; then
            if package_has_script "$project_root" "test:unit"; then
              ran=1
              echo "Running TypeScript/JavaScript unit tests..."
              run_package_script "$project_root" "test:unit" || return 1
            elif package_has_script "$project_root" "test"; then
              ran=1
              echo "Running TypeScript/JavaScript tests..."
              run_package_script "$project_root" "test" || return 1
            else
              config_path="$(first_glob_match "$project_root/vitest.config.*" "$project_root/jest.config.*" || true)"
              if [[ -n "$config_path" ]]; then
                ran=1
                case "$config_path" in
                  *vitest*)
                    echo "Running vitest..."
                    (cd "$project_root" && npx vitest run --config "$config_path") || return 1
                    ;;
                  *jest*)
                    echo "Running jest..."
                    (cd "$project_root" && npx jest --config "$config_path") || return 1
                    ;;
                esac
              fi
            fi
          fi
          ;;&
        unknown)
          if make_target_exists "$project_root" "test"; then
            ran=1
            echo "Running make test..."
            (cd "$project_root" && make test) || return 1
          fi
          ;;
      esac
      ;;
    integration)
      case "$stack" in
        python|fullstack)
          test_path="$(first_existing_path "$project_root/tests/integration" "$project_root/integration" "$project_root/test/integration" || true)"
          if [[ -n "$test_path" ]]; then
            ran=1
            echo "Running Python integration tests..."
            run_python_pytest "$project_root" "$test_path" || return 1
          fi
          ;;&
        typescript|fullstack)
          if [[ -f "$project_root/package.json" ]]; then
            if package_has_script "$project_root" "test:integration"; then
              ran=1
              echo "Running TypeScript/JavaScript integration tests..."
              run_package_script "$project_root" "test:integration" || return 1
            else
              config_path="$(first_glob_match "$project_root/vitest.integration.config.*" "$project_root/jest.integration.config.*" || true)"
              if [[ -n "$config_path" ]]; then
                ran=1
                case "$config_path" in
                  *vitest*)
                    echo "Running vitest integration suite..."
                    (cd "$project_root" && npx vitest run --config "$config_path") || return 1
                    ;;
                  *jest*)
                    echo "Running jest integration suite..."
                    (cd "$project_root" && npx jest --config "$config_path") || return 1
                    ;;
                esac
              fi
            fi
          fi
          ;;&
        unknown)
          if make_target_exists "$project_root" "integration-test"; then
            ran=1
            echo "Running make integration-test..."
            (cd "$project_root" && make integration-test) || return 1
          elif make_target_exists "$project_root" "test-integration"; then
            ran=1
            echo "Running make test-integration..."
            (cd "$project_root" && make test-integration) || return 1
          fi
          ;;
      esac
      ;;
    e2e)
      if [[ -f "$project_root/package.json" ]] && package_has_script "$project_root" "test:e2e"; then
        ran=1
        echo "Running end-to-end tests..."
        run_package_script "$project_root" "test:e2e" || return 1
      elif [[ -f "$project_root/package.json" ]] && package_has_script "$project_root" "e2e"; then
        ran=1
        echo "Running end-to-end tests..."
        run_package_script "$project_root" "e2e" || return 1
      else
        config_path="$(first_glob_match "$project_root/playwright.config.ts" "$project_root/playwright.config.js" || true)"
        if [[ -n "$config_path" ]]; then
          ran=1
          echo "Running Playwright E2E tests..."
          (cd "$project_root" && npx playwright test) || return 1
        fi
      fi
      ;;
    a11y)
      if [[ -f "$project_root/package.json" ]] && package_has_script "$project_root" "test:a11y"; then
        ran=1
        echo "Running accessibility checks..."
        run_package_script "$project_root" "test:a11y" || return 1
      elif [[ -f "$project_root/package.json" ]] && package_has_script "$project_root" "a11y"; then
        ran=1
        echo "Running accessibility checks..."
        run_package_script "$project_root" "a11y" || return 1
      elif [[ -f "$project_root/package.json" ]] && package_has_script "$project_root" "test:accessibility"; then
        ran=1
        echo "Running accessibility checks..."
        run_package_script "$project_root" "test:accessibility" || return 1
      fi
      ;;
    perf)
      case "$stack" in
        python|fullstack)
          test_path="$(first_existing_path "$project_root/tests/perf" "$project_root/tests/performance" "$project_root/perf" || true)"
          if [[ -n "$test_path" ]]; then
            ran=1
            echo "Running Python performance checks..."
            run_python_pytest "$project_root" "$test_path" || return 1
          fi
          ;;&
        typescript|fullstack)
          if [[ -f "$project_root/package.json" ]] && package_has_script "$project_root" "test:perf"; then
            ran=1
            echo "Running performance checks..."
            run_package_script "$project_root" "test:perf" || return 1
          elif [[ -f "$project_root/package.json" ]] && package_has_script "$project_root" "perf"; then
            ran=1
            echo "Running performance checks..."
            run_package_script "$project_root" "perf" || return 1
          fi
          ;;&
        unknown)
          if make_target_exists "$project_root" "perf-test"; then
            ran=1
            echo "Running make perf-test..."
            (cd "$project_root" && make perf-test) || return 1
          elif make_target_exists "$project_root" "test-perf"; then
            ran=1
            echo "Running make test-perf..."
            (cd "$project_root" && make test-perf) || return 1
          fi
          ;;
      esac
      ;;
    *)
      echo "[warn] Unsupported test tier: $tier"
      return 1
      ;;
  esac

  printf -v "$result_var" '%s' "$ran"
  return 0
}

run_test() {
  local stack exit_code=0
  local configured_profile=""
  local selected_profile=""
  local resolved_profile_label=""
  local requested_tier=""
  local tier_ran=0
  local tier_ran_any=0
  local any_tier_ran=0
  local root_label=""
  local -a requested_tiers=()
  local -a selected_tiers=()
  local -a project_roots=()
  local -A seen_tiers=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tier)
        requested_tier="${2:?Missing value for --tier}"
        if ! expand_test_profile "$requested_tier" >/dev/null 2>&1; then
          echo "Unsupported test tier: $requested_tier" >&2
          echo "Allowed values: unit integration e2e a11y perf security all" >&2
          return 1
        fi
        requested_tiers+=("$requested_tier")
        shift 2
        ;;
      --profile|--test-tier)
        selected_profile="${2:?Missing value for $1}"
        if ! expand_test_profile "$selected_profile" >/dev/null 2>&1; then
          echo "Unsupported test profile: $selected_profile" >&2
          echo "Allowed values: smoke standard full unit integration e2e a11y perf security all" >&2
          return 1
        fi
        shift 2
        ;;
      --e2e)
        requested_tiers+=("e2e")
        shift
        ;;
      *) break ;;
    esac
  done

  configured_profile="$(read_kite_test_profile "$target_dir")"
  if ! expand_test_profile "$configured_profile" >/dev/null 2>&1; then
    echo "[warn] Unsupported workflow.test_tier '$configured_profile' in .kite/config.yml; falling back to standard"
    configured_profile="standard"
  fi

  if [[ ${#requested_tiers[@]} -eq 0 ]]; then
    if [[ -z "$selected_profile" ]]; then
      selected_profile="$configured_profile"
    fi
    resolved_profile_label="$selected_profile"

    while IFS= read -r requested_tier; do
      [[ -n "$requested_tier" ]] || continue
      if [[ -z "${seen_tiers[$requested_tier]:-}" ]]; then
        selected_tiers+=("$requested_tier")
        seen_tiers["$requested_tier"]=1
      fi
    done < <(expand_test_profile "$selected_profile")
  else
    if [[ -n "$selected_profile" ]]; then
      resolved_profile_label="$selected_profile + explicit tiers"
      while IFS= read -r requested_tier; do
        [[ -n "$requested_tier" ]] || continue
        if [[ -z "${seen_tiers[$requested_tier]:-}" ]]; then
          selected_tiers+=("$requested_tier")
          seen_tiers["$requested_tier"]=1
        fi
      done < <(expand_test_profile "$selected_profile")
    else
      resolved_profile_label="explicit tiers"
    fi

    for requested_tier in "${requested_tiers[@]}"; do
      while IFS= read -r stack; do
        [[ -n "$stack" ]] || continue
        if [[ -z "${seen_tiers[$stack]:-}" ]]; then
          selected_tiers+=("$stack")
          seen_tiers["$stack"]=1
        fi
      done < <(expand_test_profile "$requested_tier")
    done
  fi

  local -a project_roots=()
  while IFS= read -r root; do
    project_roots+=("$root")
  done < <(discover_project_roots "$target_dir")

  echo "Test target: $target_dir"
  echo "Resolved test profile: $resolved_profile_label"
  echo "Selected tiers: ${selected_tiers[*]}"
  echo ""

  for requested_tier in "${selected_tiers[@]}"; do
    if [[ "$requested_tier" == "security" ]]; then
      echo "=== Tier: security ==="
      if ! run_audit; then
        exit_code=1
      fi
      any_tier_ran=1
      echo ""
      continue
    fi

    echo "=== Tier: $requested_tier ==="
    tier_ran_any=0

    for project_root in "${project_roots[@]}"; do
      stack="$(detect_stack "$project_root")"
      root_label="${project_root#"$target_dir"}"
      root_label="${root_label:-/}"
      echo "Test target: $project_root ($root_label)"
      echo "Detected stack: $stack"
      echo ""

      tier_ran=0
      if ! run_test_tier_for_root "$requested_tier" "$project_root" "$stack" tier_ran; then
        exit_code=1
      fi
      if [[ "$tier_ran" == "1" ]]; then
        any_tier_ran=1
        tier_ran_any=1
      fi
      echo ""
    done

    if [[ $tier_ran_any -eq 0 ]]; then
      echo "[info] No $requested_tier checks discovered for selected targets"
      echo ""
    fi
  done

  if [[ $any_tier_ran -eq 0 ]]; then
    echo "[warn] No test runners or tier-specific scripts were discovered for the selected tiers."
    exit_code=1
  fi

  echo ""
  if [[ $exit_code -eq 0 ]]; then
    echo "Test status: passed"
  else
    echo "Test status: failed"
  fi
  return $exit_code
}

run_audit() {
  local stack fix_mode=0 exit_code=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fix) fix_mode=1; shift ;;
      *) break ;;
    esac
  done

  echo "Audit target: $target_dir"
  echo ""

  if command -v git >/dev/null 2>&1 && git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
    local env_files
    env_files="$(git -C "$target_dir" ls-files '*.env' '.env.*' 2>/dev/null | grep -v '.env.example' | grep -v '.env.template' || true)"
    if [[ -n "$env_files" ]]; then
      echo "[warn] Committed .env files detected (may contain secrets):"
      while IFS= read -r env_file; do
        printf '  %s\n' "$env_file"
      done <<< "$env_files"
      exit_code=1
    else
      echo "[ok] No committed .env files with potential secrets"
    fi
  fi

  local -a project_roots=()
  while IFS= read -r root; do
    project_roots+=("$root")
  done < <(discover_project_roots "$target_dir")

  for project_root in "${project_roots[@]}"; do
    stack="$(detect_stack "$project_root")"
    local root_label="${project_root#"$target_dir"}"
    root_label="${root_label:-/}"
    echo ""
    echo "Auditing: $project_root ($stack)"

    case "$stack" in
      python|fullstack)
        echo "Running Python dependency audit..."
        if command -v uv >/dev/null 2>&1; then
          if [[ $fix_mode -eq 1 ]]; then
            (cd "$project_root" && uv pip audit 2>/dev/null) || {
              echo "[info] uv pip audit not available; trying pip-audit directly"
              (cd "$project_root" && uvx pip-audit) || exit_code=1
            }
          else
            (cd "$project_root" && uvx pip-audit) || exit_code=1
          fi
        elif command -v pip-audit >/dev/null 2>&1; then
          (cd "$project_root" && pip-audit) || exit_code=1
        else
          echo "[info] pip-audit not available. Install with: uvx pip-audit"
        fi
        ;;&
      typescript|fullstack)
        echo "Running JavaScript dependency audit..."
        if command -v pnpm >/dev/null 2>&1 && [[ -f "$project_root/pnpm-lock.yaml" ]]; then
          if [[ $fix_mode -eq 1 ]]; then
            (cd "$project_root" && pnpm audit --fix) || exit_code=1
          else
            (cd "$project_root" && pnpm audit) || exit_code=1
          fi
        elif command -v npm >/dev/null 2>&1 && [[ -f "$project_root/package-lock.json" ]]; then
          if [[ $fix_mode -eq 1 ]]; then
            (cd "$project_root" && npm audit fix) || exit_code=1
          else
            (cd "$project_root" && npm audit) || exit_code=1
          fi
        else
          echo "[info] No lock file found for npm/pnpm audit"
        fi
        ;;&
      unknown)
        if [[ "$project_root" == "$target_dir" ]]; then
          echo "[info] Unknown stack; only general checks were performed"
        fi
        ;;
    esac
  done

  echo ""
  if [[ $exit_code -eq 0 ]]; then
    echo "Audit status: clean"
  else
    echo "Audit status: findings detected"
  fi
  return $exit_code
}

get_active_feature_dir() {
  local target="$1"

  if [[ -f "$target/.specify/feature.json" ]]; then
    local feature_name
    if command -v jq >/dev/null 2>&1; then
      feature_name="$(jq -r '.name // empty' "$target/.specify/feature.json" 2>/dev/null || true)"
    fi
    if [[ -n "$feature_name" && -d "$target/specs/$feature_name" ]]; then
      printf '%s\n' "$target/specs/$feature_name"
      return 0
    fi
  fi

  if command -v git >/dev/null 2>&1 && git -C "$target" rev-parse --git-dir >/dev/null 2>&1; then
    local current_branch
    current_branch="$(git -C "$target" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    if [[ -n "$current_branch" ]]; then
      local feature_slug="${current_branch##*/}"
      if [[ -d "$target/specs/$feature_slug" ]]; then
        printf '%s\n' "$target/specs/$feature_slug"
        return 0
      fi
    fi
  fi

  if [[ -d "$target/specs" ]]; then
    local -a dirs=()
    while IFS= read -r -d '' d; do
      dirs+=("$d")
    done < <(find "$target/specs" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
    if [[ ${#dirs[@]} -eq 1 ]]; then
      printf '%s\n' "${dirs[0]}"
      return 0
    fi
  fi

  return 1
}

find_active_tasks_file() {
  local feature_dir
  feature_dir="$(get_active_feature_dir "$target_dir")" || return 1

  if [[ -f "$feature_dir/tasks.md" ]]; then
    printf '%s\n' "$feature_dir/tasks.md"
    return 0
  fi

  return 1
}

run_verify_feature() {
  local issues=0
  local feature_branch_suggestion

  feature_branch_suggestion="$(suggest_feature_branch_name)"
  echo "Verify-feature target: $target_dir"

  if ! command -v git >/dev/null 2>&1 || ! git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
    echo "[warn] Not a git repository"
    print_recovery_block \
      "kite verify feature needs a git repository so it can inspect branch state, conflicts, and tracked task progress." \
      "$(error_doc_path "verify-feature-not-a-git-repo.md")" \
      "$(shell_join git init)" \
      "$(shell_join git checkout -b "$feature_branch_suggestion")"
    return 1
  fi

  local current_branch
  current_branch="$(git -C "$target_dir" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  local default_branch
  default_branch="$(default_branch_name "$target_dir")"

  if [[ -z "$current_branch" ]]; then
    echo "[warn] Could not determine current branch"
    print_recovery_block \
      "Detached HEAD or a missing branch ref leaves kite without a feature branch to verify." \
      "$(error_doc_path "verify-feature-unknown-branch.md")" \
      "$(shell_join git checkout -b "$feature_branch_suggestion")"
    issues=1
  elif [[ "$current_branch" == "$default_branch" ]]; then
    echo "[warn] Currently on $default_branch; switch to a feature branch first"
    print_recovery_block \
      "Pre-merge verification belongs on a feature branch so $default_branch stays the merge target instead of the work branch." \
      "$(error_doc_path "verify-feature-default-branch.md")" \
      "$(shell_join git checkout -b "$feature_branch_suggestion")"
    issues=1
  else
    echo "[ok] active feature branch: $current_branch"
  fi

  if [[ -n "$(git -C "$target_dir" status --porcelain)" ]]; then
    echo "[warn] Working tree has uncommitted changes"
    print_recovery_block \
      "Uncommitted work makes merge-readiness ambiguous; checkpoint or stash it before running the gate." \
      "$(error_doc_path "verify-feature-dirty-tree.md")" \
      "$(shell_join git status --short)" \
      "$(shell_join git stash push -u -m "pre-verify cleanup")"
    issues=1
  else
    echo "[ok] Working tree is clean"
  fi

  local conflict_files=""
  while IFS= read -r -d '' fname; do
    if grep -ql '^<<<<<<< ' "$target_dir/$fname" 2>/dev/null; then
      conflict_files+="  $fname"$'\n'
    fi
  done < <(git -C "$target_dir" ls-files -z 2>/dev/null)

  if [[ -n "$conflict_files" ]]; then
    echo "[warn] Merge conflict markers found:"
    printf '%s' "$conflict_files"
    print_recovery_block \
      "Conflict markers mean the branch is not in a reviewable state yet; resolve and re-stage the files first." \
      "$(error_doc_path "verify-feature-merge-conflicts.md")" \
      "$(shell_join git diff --name-only --diff-filter=U)" \
      "$(shell_join git add "<resolved-files>")"
    issues=1
  else
    echo "[ok] No merge conflict markers"
  fi

  local tasks_file
  tasks_file="$(find_active_tasks_file)" || true

  if [[ -n "$tasks_file" && -f "$tasks_file" ]]; then
    echo "[ok] Active tasks file: $tasks_file"
    local incomplete
    incomplete="$(grep -cE '^\s*-\s*\[ \]' "$tasks_file" 2>/dev/null || true)"
    if [[ "$incomplete" -gt 0 ]]; then
      local rel_tasks task_lookup_path
      rel_tasks="${tasks_file#"$target_dir/"}"
      task_lookup_path="$tasks_file"
      if [[ "$rel_tasks" != "$tasks_file" ]]; then
        task_lookup_path="$rel_tasks"
      fi
      echo "[warn] $incomplete incomplete task(s) in $tasks_file"
      print_recovery_block \
        "The active tasks file still shows open work, so merge review would skip declared scope or verification steps." \
        "$(error_doc_path "verify-feature-incomplete-tasks.md")" \
        "$(shell_join grep -nE '^\s*-\s*\[ \]' "$task_lookup_path")" \
        "$(build_kite_command feature)"
      issues=1
    else
      local rel_tasks="${tasks_file#"$target_dir/"}"
      echo "[ok] tracked tasks are complete in $rel_tasks"
    fi
  else
    echo "[info] no active Speckit tasks file was identified for this branch"
  fi

  if [[ $issues -eq 0 ]]; then
    echo "Verification status: ready for merge review"
    return 0
  fi

  echo "Verification status: action needed"
  return 1
}

# Compute the most recent modification time (unix epoch) of a file.
_file_mtime() {
  local file="$1"
  [[ -f "$file" ]] || { echo 0; return; }
  stat -c '%Y' "$file" 2>/dev/null || stat -f '%m' "$file" 2>/dev/null || echo 0
}

# Format a unix epoch as a relative-time string (e.g. "3h ago").
_relative_time() {
  local epoch="$1"
  [[ "$epoch" =~ ^[0-9]+$ ]] || { echo "unknown"; return; }
  [[ "$epoch" -eq 0 ]] && { echo "never"; return; }
  local now delta
  now="$(date +%s)"
  delta=$((now - epoch))
  if (( delta < 60 )); then echo "just now"
  elif (( delta < 3600 )); then echo "$((delta/60))m ago"
  elif (( delta < 86400 )); then echo "$((delta/3600))h ago"
  elif (( delta < 604800 )); then echo "$((delta/86400))d ago"
  else echo "$((delta/604800))w ago"
  fi
}

run_feature_status() {
  local as_json="${1:-0}"
  local feature_dir feature_name branch=""
  local -a artifact_paths=() artifact_labels=()
  local -a present_labels=() pending_labels=() recent_lines=()
  local current_stage="unknown" next_action="" next_command=""

  feature_dir="$(get_active_feature_dir "$target_dir" 2>/dev/null || true)"

  if command -v git >/dev/null 2>&1 && git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
    branch="$(git -C "$target_dir" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  fi

  if [[ -z "$feature_dir" ]]; then
    if [[ "$as_json" -eq 1 ]]; then
      printf '{"status":"no-active-feature","branch":%s,"hint":%s}\n' \
        "$(json_escape "$branch")" \
        "$(json_escape "Run kite install speckit ., align the feature branch and .specify/feature.json, then /speckit.discover \"your feature idea\".")"
    else
      echo "No active Speckit feature detected."
      echo ""
      echo "Hints:"
      echo "  - Current branch: ${branch:-<none>}"
      echo "  - Run: kite install speckit ."
      echo "  - Align the feature branch and .specify/feature.json"
      echo "  - Then: /speckit.discover \"your feature idea\""
    fi
    return 0
  fi

  feature_name="$(basename "$feature_dir")"

  # Canonical artifact checklist (stage -> path label).
  # Order matters: it drives the "current stage" detection.
  artifact_labels=(
    "discover"
    "constitution"
    "specify"
    "design"
    "plan"
    "tasks"
    "analyze"
    "test"
    "review"
    "release"
    "operate"
    "learn"
  )
  artifact_paths=(
    "$feature_dir/discovery.md"
    "$target_dir/.specify/memory/constitution.md"
    "$feature_dir/spec.md"
    "$target_dir/.specify/memory/design-direction.md"
    "$feature_dir/plan.md"
    "$feature_dir/tasks.md"
    "$feature_dir/analyze.md"
    "$feature_dir/test-results.md"
    "$feature_dir/review.md"
    "$feature_dir/release.md"
    "$feature_dir/operate.md"
    "$feature_dir/learn.md"
  )

  # Walk in order; last present artifact defines the current stage.
  local i count=${#artifact_labels[@]}
  for (( i=0; i<count; i++ )); do
    local label="${artifact_labels[$i]}"
    local path="${artifact_paths[$i]}"
    if [[ -f "$path" ]]; then
      present_labels+=("$label")
      current_stage="$label"
    else
      pending_labels+=("$label")
    fi
  done

  # Pick next action from the first pending artifact.
  if (( ${#pending_labels[@]} > 0 )); then
    case "${pending_labels[0]}" in
      discover)     next_action="Align feature context, then capture discovery for the feature"; next_command="/speckit.discover" ;;
      constitution) next_action="Lock project standards";          next_command="/speckit.constitution" ;;
      specify)      next_action="Write the feature spec";          next_command="/speckit.specify" ;;
      design)       next_action="Define design direction";         next_command="Designer agent or /speckit.design" ;;
      plan)         next_action="Produce the technical plan";      next_command="/speckit.plan" ;;
      tasks)        next_action="Break work into tasks";           next_command="/speckit.tasks" ;;
      analyze)      next_action="Run consistency analysis";        next_command="/speckit.analyze" ;;
      test)         next_action="Run and capture test results";    next_command="/speckit.test" ;;
      review)       next_action="Synthesize the code review";      next_command="Code Reviewer agent" ;;
      release)      next_action="Prepare the release";             next_command="kite release prepare --bump <level> ." ;;
      operate)      next_action="Capture monitoring & alerts";     next_command="DevOps agent (operate stage)" ;;
      learn)        next_action="Record post-release learnings";   next_command="Orchestrator (learn stage)" ;;
    esac
  else
    next_action="All canonical artifacts present"
    next_command="kite verify feature ."
  fi

  # Build "recent artifacts" list sorted by mtime desc.
  local -a mtime_rows=()
  for (( i=0; i<count; i++ )); do
    local path="${artifact_paths[$i]}"
    [[ -f "$path" ]] || continue
    local mt rel
    mt="$(_file_mtime "$path")"
    rel="${path#"$target_dir/"}"
    mtime_rows+=("${mt}|${artifact_labels[$i]}|${rel}")
  done

  local -a sorted_rows=()
  if (( ${#mtime_rows[@]} > 0 )); then
    while IFS= read -r line; do
      sorted_rows+=("$line")
    done < <(printf '%s\n' "${mtime_rows[@]}" | sort -t '|' -k1,1nr)
  fi

  local max=3 shown=0 line
  for line in "${sorted_rows[@]:-}"; do
    [[ -z "$line" ]] && continue
    (( shown >= max )) && break
    local mt rest label rel
    mt="${line%%|*}"
    rest="${line#*|}"
    label="${rest%%|*}"
    rel="${rest#*|}"
    recent_lines+=("$(printf '%-12s %s (%s)' "$label" "$rel" "$(_relative_time "$mt")")")
    shown=$((shown + 1))
  done

  if [[ "$as_json" -eq 1 ]]; then
    # Build JSON arrays via json_array helper.
    local present_json pending_json
    present_json="$(json_array "${present_labels[@]+"${present_labels[@]}"}")"
    pending_json="$(json_array "${pending_labels[@]+"${pending_labels[@]}"}")"
    local recent_json="[" first=1 r
    for r in "${recent_lines[@]:-}"; do
      [[ -z "$r" ]] && continue
      if [[ $first -eq 1 ]]; then first=0; else recent_json+=","; fi
      recent_json+="$(json_escape "$r")"
    done
    recent_json+="]"

    printf '{"status":"active","feature":%s,"feature_dir":%s,"branch":%s,"current_stage":%s,"present":%s,"pending":%s,"recent":%s,"next_action":%s,"next_command":%s}\n' \
      "$(json_escape "$feature_name")" \
      "$(json_escape "${feature_dir#"$target_dir/"}")" \
      "$(json_escape "$branch")" \
      "$(json_escape "$current_stage")" \
      "$present_json" \
      "$pending_json" \
      "$recent_json" \
      "$(json_escape "$next_action")" \
      "$(json_escape "$next_command")"
    return 0
  fi

  echo "Feature:  $feature_name"
  echo "Branch:   ${branch:-<none>}"
  echo "Stage:    $current_stage"
  echo ""
  echo "Artifacts:"
  for (( i=0; i<count; i++ )); do
    local label="${artifact_labels[$i]}"
    local path="${artifact_paths[$i]}"
    if [[ -f "$path" ]]; then
      printf '  [x] %-12s %s\n' "$label" "${path#"$target_dir/"}"
    else
      printf '  [ ] %-12s %s\n' "$label" "${path#"$target_dir/"}"
    fi
  done

  if (( ${#recent_lines[@]} > 0 )); then
    echo ""
    echo "Recently changed:"
    local rline
    for rline in "${recent_lines[@]}"; do
      echo "  $rline"
    done
  fi

  echo ""
  echo "Next action: $next_action"
  if [[ -n "$next_command" ]]; then
    echo "Run:         $next_command"
  fi
}

run_explain() {
  local stage="${1:-}"
  if [[ -z "$stage" || "$stage" == "-h" || "$stage" == "--help" ]]; then
    show_help "explain"
    return 0
  fi

  case "$stage" in
    discover)
      cat <<'EOF'
Stage: discover

What it is:
  A canonical discovery pass that turns an idea into a concrete problem,
  user, outcome, and success signal before technical specification starts.

Who runs it:
  /speckit.discover after Strategist has pressure-tested the direction.
  Marketer is optional when audience or market-fit confidence is still weak.

What comes out:
  specs/<feature>/discovery.md and, when needed,
  specs/<feature>/market-validation.md.

Next:
  /speckit.constitution, then /speckit.specify.
EOF
      ;;
    constitution)
      cat <<'EOF'
Stage: constitution

What it is:
  Project-wide standards and non-negotiables: coding style, testing bar,
  accessibility, performance budgets, security posture.

Who runs it:
  /speckit.constitution command.

What comes out:
  .specify/memory/constitution.md — read by every later stage.

Next:
  /speckit.specify once the constitution is approved.
EOF
      ;;
    specify)
      cat <<'EOF'
Stage: specify

What it is:
  Formal feature spec: user stories, functional requirements (FR IDs),
  acceptance criteria, and scope boundaries.

Who runs it:
  /speckit.specify command. Ask clarification questions before writing.

What comes out:
  specs/<feature>/spec.md — the source of truth for what must be built.

Next:
  Designer agent or /speckit.design for UI features, then /speckit.plan.
EOF
      ;;
    design)
      cat <<'EOF'
Stage: design

What it is:
  Visual direction, design system, color, typography, spacing, component
  principles. Only needed for features with UI surface.

Who runs it:
  Designer agent (interactive) or /speckit.design.

What comes out:
  .specify/memory/design-direction.md — read by UI Builder during build.

Next:
  /speckit.plan — technical plan that references the design direction.
EOF
      ;;
    plan)
      cat <<'EOF'
Stage: plan

What it is:
  Technical plan: architecture, data model, APIs, tech choices, risks.

Who runs it:
  /speckit.plan command.

What comes out:
  specs/<feature>/plan.md.

Next:
  /speckit.tasks — break the plan into a checklist of concrete tasks.
EOF
      ;;
    tasks)
      cat <<'EOF'
Stage: tasks

What it is:
  Ordered checklist of implementation tasks, each with an ID and mapped
  to FR IDs from the spec.

Who runs it:
  /speckit.tasks command.

What comes out:
  specs/<feature>/tasks.md.

Next:
  /speckit.analyze to check consistency, then Backend Dev / UI Builder to
  execute tasks.
EOF
      ;;
    analyze)
      cat <<'EOF'
Stage: analyze

What it is:
  Consistency and coverage check across spec, plan, and tasks. Catches
  missing requirements and orphan tasks before coding starts.

Who runs it:
  /speckit.analyze command.

What comes out:
  A report (stored under specs/<feature>/ or in chat) with issues to fix.

Next:
  Fix any gaps, then begin implementation.
EOF
      ;;
    implement)
      cat <<'EOF'
Stage: implement

What it is:
  Writing the code for the tasks in specs/<feature>/tasks.md.

Who runs it:
  Backend Dev agent (APIs, jobs, data) and UI Builder agent (frontend).
  Both reference the spec, plan, design direction, and tasks.

What comes out:
  Working code on the feature branch, with task checkboxes ticked.

Next:
  /speckit.test to verify.
EOF
      ;;
    test)
      cat <<'EOF'
Stage: test

What it is:
  Tiered verification: unit, integration, e2e, accessibility, performance,
  and security checks selected by repo defaults or feature risk.

Who runs it:
  /speckit.test command, then kite test for the stack's native runners and
  configured verification profile.

What comes out:
  Passing test suite and a short summary (optionally under
  specs/<feature>/test-results.md).

Next:
  Code Reviewer agent for a review pass.
EOF
      ;;
    review)
      cat <<'EOF'
Stage: review

What it is:
  Multi-perspective code review: correctness, security, performance,
  clarity. Outputs a prioritized action list.

Who runs it:
  Code Reviewer agent.

What comes out:
  A review summary and any fix commits.

Next:
  kite verify feature to confirm merge-readiness.
EOF
      ;;
    verify)
      cat <<'EOF'
Stage: verify

What it is:
  Pre-merge checklist: clean working tree, on a feature branch, no merge
  conflicts, tasks complete.

Who runs it:
  kite verify feature .

What comes out:
  "Verification status: ready for merge review" or a list of items to fix.

Next:
  Open a pull request; after merge, proceed to release.
EOF
      ;;
    release)
      cat <<'EOF'
Stage: release

What it is:
  A two-step release flow: `prepare` proves the feature branch is ready,
  then `publish` bumps the version, updates the changelog, and tags the
  default branch.

Who runs it:
  kite release prepare --bump <patch|minor|major> .
  After merge: kite release publish --bump <patch|minor|major> --confirm .

What comes out:
  A release preview with gates and notes, then a tagged commit and
  updated CHANGELOG.md on publish.

Next:
  Operate — watch the release in production.
EOF
      ;;
    operate)
      cat <<'EOF'
Stage: operate

What it is:
  Monitoring, logging, alerts, and incident response for the shipped
  feature.

Who runs it:
  DevOps agent; results captured in specs/<feature>/operate.md.

What comes out:
  Dashboards, alert rules, and a runbook snippet for on-call.

Next:
  Learn — capture feedback and feed it back into discovery.
EOF
      ;;
    learn)
      cat <<'EOF'
Stage: learn

What it is:
  Post-release reflection: what users did, what broke, what to build
  next.

Who runs it:
  Orchestrator (loops back to Strategist / Marketer as needed).

What comes out:
  specs/<feature>/learn.md with metrics, quotes, and next-bet ideas.

Next:
  A new discover loop for the follow-up feature.
EOF
      ;;
    *)
      echo "Unknown stage: $stage" >&2
      echo "" >&2
      show_help "explain" >&2
      return 1
      ;;
  esac
}

bump_version() {
  local bump_type="$1"
  local version_file="" current_version=""

  if [[ -f "$target_dir/package.json" ]]; then
    version_file="package.json"
    if command -v jq >/dev/null 2>&1; then
      current_version="$(jq -r '.version // empty' "$target_dir/package.json" 2>/dev/null || true)"
    else
      current_version="$(node -e "console.log(require('./package.json').version || '')" 2>/dev/null || true)"
    fi
  elif [[ -f "$target_dir/pyproject.toml" ]]; then
    version_file="pyproject.toml"
    current_version="$(grep -m1 '^version' "$target_dir/pyproject.toml" | sed 's/.*= *"\([^"]*\)".*/\1/' || true)"
  elif [[ -f "$target_dir/VERSION" ]]; then
    version_file="VERSION"
    current_version="$(tr -d '[:space:]' < "$target_dir/VERSION" 2>/dev/null || true)"
  fi

  if [[ -z "$version_file" || -z "$current_version" ]]; then
    echo "[warn] No version source found (package.json, pyproject.toml, or VERSION file)" >&2
    return 1
  fi

  if [[ ! "$current_version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "[warn] Version '$current_version' is not a standard X.Y.Z format; cannot bump safely" >&2
    return 1
  fi

  local IFS='.'
  read -r major minor patch <<< "$current_version"
  major="${major:-0}"
  minor="${minor:-0}"
  patch="${patch:-0}"

  case "$bump_type" in
    major) major=$((major + 1)); minor=0; patch=0 ;;
    minor) minor=$((minor + 1)); patch=0 ;;
    patch) patch=$((patch + 1)) ;;
  esac

  local new_version="$major.$minor.$patch"
  printf '%s %s %s\n' "$version_file" "$current_version" "$new_version"
}

  validate_release_bump_type() {
    local bump_type="$1"

    case "$bump_type" in
      major|minor|patch) return 0 ;;
      *)
        echo "Unknown bump type: $bump_type (expected: major, minor, patch)" >&2
        return 1
        ;;
    esac
  }

  latest_release_tag() {
    local target="$1"
    git -C "$target" describe --tags --abbrev=0 2>/dev/null || true
  }

  github_repo_slug() {
    local target="$1"
    local remote_url slug=""

    remote_url="$(git -C "$target" remote get-url origin 2>/dev/null || true)"

    case "$remote_url" in
      git@github.com:*) slug="${remote_url#git@github.com:}" ;;
      ssh://git@github.com/*) slug="${remote_url#ssh://git@github.com/}" ;;
      https://github.com/*) slug="${remote_url#https://github.com/}" ;;
    esac

    slug="${slug%.git}"
    if [[ "$slug" == */* ]]; then
      printf '%s\n' "$slug"
      return 0
    fi

    return 1
  }

  collect_release_pr_titles_via_gh() {
    local target="$1"
    local default_branch="$2"
    local since_date="$3"
    local repo_slug pr_lines=""

    command -v gh >/dev/null 2>&1 || return 1

    repo_slug="$(github_repo_slug "$target" 2>/dev/null || true)"
    [[ -n "$repo_slug" ]] || return 1

    pr_lines="$(gh pr list \
      --repo "$repo_slug" \
      --state merged \
      --base "$default_branch" \
      --limit 100 \
      --search "merged:>=$since_date" \
      --json number,title,mergedAt \
      --jq 'sort_by(.mergedAt) | .[] | "- #" + (.number | tostring) + " " + .title' \
      2>/dev/null || true)"

    if [[ -n "${pr_lines//[[:space:]]/}" ]]; then
      printf '%s\n' "$pr_lines"
      return 0
    fi

    return 1
  }

  collect_release_pr_titles_from_git() {
    local target="$1"
    local last_tag="$2"
    local range="HEAD"
    local printed=1 subject

    if [[ -n "$last_tag" ]]; then
      range="$last_tag..HEAD"
    fi

    while IFS= read -r subject; do
      [[ -n "$subject" ]] || continue
      printf -- '- %s\n' "$subject"
      printed=0
    done < <(git -C "$target" log --first-parent --pretty=format:%s "$range" 2>/dev/null | grep -vE '^release: v' || true)

    return $printed
  }

  collect_release_pr_titles() {
    local target="$1"
    local default_branch="$2"
    local last_tag="$3"
    local since_date="1970-01-01"

    if [[ -n "$last_tag" ]]; then
      since_date="$(git -C "$target" log -1 --format=%cs "$last_tag" 2>/dev/null || printf '1970-01-01')"
    fi

    collect_release_pr_titles_via_gh "$target" "$default_branch" "$since_date" || \
      collect_release_pr_titles_from_git "$target" "$last_tag"
  }

  extract_unreleased_changelog_body() {
    local changelog_file="$1/CHANGELOG.md"

    [[ -f "$changelog_file" ]] || return 0

    awk '
      /^## \[Unreleased\]$/ { capture=1; next }
      capture && /^## \[/ { exit }
      capture { print }
    ' "$changelog_file"
  }

  build_release_notes() {
    local target="$1"
    local new_version="$2"
    local default_branch="$3"
    local last_tag="$4"
    local release_date pr_lines unreleased_body

    release_date="$(date +%Y-%m-%d)"
    pr_lines="$(collect_release_pr_titles "$target" "$default_branch" "$last_tag" || true)"
    unreleased_body="$(extract_unreleased_changelog_body "$target" || true)"

    printf '## [%s] - %s\n' "$new_version" "$release_date"

    if [[ -n "${pr_lines//[[:space:]]/}" ]]; then
      printf '\n### Pull Requests\n%s\n' "$pr_lines"
    fi

    if [[ -n "${unreleased_body//[[:space:]]/}" ]]; then
      printf '\n%s\n' "$unreleased_body"
    elif [[ -z "${pr_lines//[[:space:]]/}" ]]; then
      printf '\n### Changed\n\n- No release-note entries were generated.\n'
    fi
  }

  write_release_notes_to_changelog() {
    local target="$1"
    local release_notes="$2"
    local changelog_file="$target/CHANGELOG.md"
    local header tail tmp_file

    [[ -f "$changelog_file" ]] || return 0

    if ! grep -q '^## \[Unreleased\]$' "$changelog_file"; then
      printf '\n%s\n' "$release_notes" >> "$changelog_file"
      return 0
    fi

    header="$(awk '1; /^## \[Unreleased\]$/ { exit }' "$changelog_file")"
    tail="$(awk '
      /^## \[Unreleased\]$/ { capture=1; found=1; next }
      capture && /^## \[/ { capture=0 }
      !capture && found { print }
    ' "$changelog_file")"

    tmp_file="$(mktemp "${TMPDIR:-/tmp}/kite-changelog.XXXXXX")"
    {
      printf '%s\n\n' "$header"
      printf '%s\n' "$release_notes"
      if [[ -n "${tail//[[:space:]]/}" ]]; then
        printf '\n%s\n' "$tail"
      fi
    } > "$tmp_file"

    mv "$tmp_file" "$changelog_file"
  }

  apply_release_version() {
    local version_file="$1"
    local current_version="$2"
    local new_version="$3"

    case "$version_file" in
      package.json)
        if command -v jq >/dev/null 2>&1; then
          local tmp_pkg
          tmp_pkg="$(jq --arg v "$new_version" '.version = $v' "$target_dir/package.json")"
          printf '%s\n' "$tmp_pkg" > "$target_dir/package.json"
        else
          (cd "$target_dir" && node -e "
            const fs = require('fs');
            const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
            pkg.version = process.argv[1];
            fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
          " "$new_version")
        fi
        ;;
      pyproject.toml)
        local escaped_current escaped_new
        escaped_current="$(printf '%s\n' "$current_version" | sed 's/[][[\.^$*]/\\&/g')"
        escaped_new="$(printf '%s\n' "$new_version" | sed 's/[&\\/]/\\&/g')"
        sed -i "s/^version = \"${escaped_current}\"/version = \"${escaped_new}\"/" "$target_dir/pyproject.toml"
        ;;
      VERSION)
        printf '%s\n' "$new_version" > "$target_dir/VERSION"
        ;;
    esac
  }

  print_release_preview() {
    local mode_label="$1"
    local current_branch="$2"
    local default_branch="$3"
    local version_file="$4"
    local current_version="$5"
    local new_version="$6"
    local tag_name="$7"
    local last_tag="$8"
    local release_notes="$9"

    echo "Release mode: $mode_label"
    echo "Current branch: ${current_branch:-<none>}"
    echo "Default branch: $default_branch"
    echo "Previous tag: ${last_tag:-<none>}"
    echo "Version source: $version_file"
    echo "Current version: $current_version"
    echo "New version: $new_version"
    echo "Tag: $tag_name"
    echo ""
    echo "Release notes preview:"
    printf '%s\n' "$release_notes"
  }

  run_release_prepare() {
    local bump_type="patch" release_dry_run=0 confirm=0 skip_checks=0
    local version_info version_file current_version new_version tag_name
    local current_branch default_branch last_tag release_notes

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --bump)
          bump_type="${2:?Missing value for --bump}"
          shift 2
          ;;
        --dry-run)
          release_dry_run=1
          shift
          ;;
        --confirm)
          confirm=1
          shift
          ;;
        --skip-checks)
          skip_checks=1
          shift
          ;;
        -h|--help)
          release_help
          return 0
          ;;
        *)
          echo "Unexpected argument: $1" >&2
          release_help >&2
          return 1
          ;;
      esac
    done

    validate_release_bump_type "$bump_type" || return 1

    echo "Release prepare target: $target_dir"

    if ! command -v git >/dev/null 2>&1 || ! git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
      echo "[warn] Not a git repository"
      return 1
    fi

    current_branch="$(git -C "$target_dir" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    default_branch="$(default_branch_name "$target_dir")"

    if [[ $skip_checks -ne 1 ]]; then
      echo ""
      echo "Running release gates on the feature branch..."
      if ! run_verify_feature; then
        echo ""
        echo "[error] Release prepare requires a clean, merge-ready feature branch."
        return 1
      fi
      if ! run_test; then
        echo ""
        echo "[error] Tests failed. Fix before preparing the release, or use --skip-checks to bypass."
        return 1
      fi
      if ! run_audit; then
        echo ""
        echo "[error] Audit has findings. Review before preparing the release, or use --skip-checks to bypass."
        return 1
      fi
      echo "Release gates passed."
    else
      echo "[warn] Skipping release gates (--skip-checks)"
    fi

    version_info="$(bump_version "$bump_type")"
    if [[ -z "$version_info" ]]; then
      return 1
    fi

    read -r version_file current_version new_version _ <<< "$version_info"
    tag_name="v$new_version"
    last_tag="$(latest_release_tag "$target_dir")"
    release_notes="$(build_release_notes "$target_dir" "$new_version" "$default_branch" "$last_tag")"

    echo ""
    print_release_preview "prepare" "$current_branch" "$default_branch" "$version_file" "$current_version" "$new_version" "$tag_name" "$last_tag" "$release_notes"

    if [[ $confirm -eq 1 ]]; then
      echo ""
      echo "[info] release prepare never mutates the repository; --confirm is ignored."
    fi
    if [[ $release_dry_run -eq 1 ]]; then
      echo ""
      echo "Dry run - no changes written"
    fi

    echo ""
    echo "Next step: merge ${current_branch:-<feature-branch>} into $default_branch, then run:"
    echo "  kite release publish --bump $bump_type --confirm $target_dir"
  }

  run_release_publish() {
    local bump_type="patch" release_dry_run=0 confirm=0 skip_checks=0
    local version_info version_file current_version new_version tag_name
    local current_branch default_branch last_tag release_notes

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --bump)
          bump_type="${2:?Missing value for --bump}"
          shift 2
          ;;
        --dry-run)
          release_dry_run=1
          shift
          ;;
        --confirm)
          confirm=1
          shift
          ;;
        --skip-checks)
          skip_checks=1
          shift
          ;;
        -h|--help)
          release_help
          return 0
          ;;
        *)
          echo "Unexpected argument: $1" >&2
          release_help >&2
          return 1
          ;;
      esac
    done

    validate_release_bump_type "$bump_type" || return 1

    echo "Release publish target: $target_dir"

    if ! command -v git >/dev/null 2>&1 || ! git -C "$target_dir" rev-parse --git-dir >/dev/null 2>&1; then
      echo "[warn] Not a git repository"
      return 1
    fi

    current_branch="$(git -C "$target_dir" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
    default_branch="$(default_branch_name "$target_dir")"

    if [[ "$current_branch" != "$default_branch" ]]; then
      echo "[warn] Publish must run from $default_branch (currently on ${current_branch:-<none>})"
      return 1
    fi

    if [[ -n "$(git -C "$target_dir" status --porcelain)" ]]; then
      echo "[warn] Working tree is not clean; commit changes first"
      return 1
    fi

    version_info="$(bump_version "$bump_type")"
    if [[ -z "$version_info" ]]; then
      return 1
    fi

    read -r version_file current_version new_version _ <<< "$version_info"
    tag_name="v$new_version"
    last_tag="$(latest_release_tag "$target_dir")"
    release_notes="$(build_release_notes "$target_dir" "$new_version" "$default_branch" "$last_tag")"

    if git -C "$target_dir" rev-parse -q --verify "refs/tags/$tag_name" >/dev/null 2>&1; then
      echo "[warn] Tag $tag_name already exists"
      return 1
    fi

    echo ""
    print_release_preview "publish" "$current_branch" "$default_branch" "$version_file" "$current_version" "$new_version" "$tag_name" "$last_tag" "$release_notes"

    if [[ $release_dry_run -eq 1 || $confirm -ne 1 ]]; then
      echo ""
      if [[ $release_dry_run -eq 1 ]]; then
        echo "Dry run - no changes written"
      else
        echo "Preview only. Re-run with --confirm to publish."
      fi
      return 0
    fi

    if [[ $skip_checks -ne 1 ]]; then
      echo ""
      echo "Running publish gates on $default_branch..."
      if ! run_test; then
        echo ""
        echo "[error] Tests failed. Fix before publishing, or use --skip-checks to bypass."
        return 1
      fi
      if ! run_audit; then
        echo ""
        echo "[error] Audit has findings. Review before publishing, or use --skip-checks to bypass."
        return 1
      fi
      echo "Publish gates passed."
    else
      echo "[warn] Skipping publish gates (--skip-checks)"
    fi

    apply_release_version "$version_file" "$current_version" "$new_version"
    write_release_notes_to_changelog "$target_dir" "$release_notes"

    git -C "$target_dir" add -A
    git -C "$target_dir" commit -m "release: v$new_version"
    git -C "$target_dir" tag -a "$tag_name" -m "Release $tag_name"

    echo ""
    echo "Release $tag_name created"
    echo "Push with: git push origin $default_branch --tags"
  }

  run_release() {
    local subcommand="publish"
    local legacy_mode=1

    if [[ $# -gt 0 ]]; then
      case "$1" in
        prepare|publish)
          subcommand="$1"
          legacy_mode=0
          shift
          ;;
        -h|--help)
          release_help
          return 0
          ;;
      esac
    fi

    if [[ $legacy_mode -eq 1 ]]; then
      echo "[info] kite release without a subcommand defaults to publish; use 'kite release prepare' for pre-merge gates."
    fi

    case "$subcommand" in
      prepare) run_release_prepare "$@" ;;
      publish) run_release_publish "$@" ;;
    esac
  }

emit_bash_completion() {
  cat <<'COMPEOF'
_kite_completion() {
  local cur prev words cword
  words=(${COMP_WORDS[*]})
  cword=$COMP_CWORD
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  local commands="install update doctor status test audit release verify feature explain completion help"
  local install_sub="speckit"
  local update_sub="workspace"
  local verify_sub="feature"
  local explain_stages="discover constitution specify design plan tasks analyze implement test review verify release operate learn"
  local update_options="--merge --dry-run --with-speckit --force-speckit-init --speckit-version --repo --ref --source-dir -h --help"
  local install_options="--force-speckit-init --speckit-version --repo --ref --source-dir -h --help"
  local doctor_options="--speckit-version --repo --ref --source-dir -h --help"
  local status_options="--json --repo --ref --source-dir -h --help"
  local feature_options="--json -h --help"
  local test_options="--tier --profile --test-tier --e2e -h --help"
  local audit_options="--fix -h --help"
  local release_subcommands="prepare publish"
  local release_options="--bump --dry-run --confirm --skip-checks -h --help"

  if [[ $cword -eq 1 ]]; then
    COMPREPLY=($(compgen -W "$commands" -- "$cur"))
    return
  fi

  local primary="${words[1]}"
  local secondary="${words[2]:-}"

  case "$primary" in
    install)
      if [[ $cword -eq 2 ]]; then
        COMPREPLY=($(compgen -W "$install_sub" -- "$cur"))
      elif [[ "$secondary" == "speckit" ]]; then
        COMPREPLY=($(compgen -W "$install_options" -- "$cur"))
      fi
      ;;
    update)
      if [[ $cword -eq 2 ]]; then
        COMPREPLY=($(compgen -W "$update_sub" -- "$cur"))
      elif [[ "$secondary" == "workspace" ]]; then
        COMPREPLY=($(compgen -W "$update_options" -- "$cur"))
      fi
      ;;
    verify)
      if [[ $cword -eq 2 ]]; then
        COMPREPLY=($(compgen -W "$verify_sub" -- "$cur"))
      fi
      ;;
    doctor) COMPREPLY=($(compgen -W "$doctor_options" -- "$cur")) ;;
    status) COMPREPLY=($(compgen -W "$status_options" -- "$cur")) ;;
    feature) COMPREPLY=($(compgen -W "$feature_options" -- "$cur")) ;;
    explain)
      if [[ $cword -eq 2 ]]; then
        COMPREPLY=($(compgen -W "$explain_stages" -- "$cur"))
      fi
      ;;
    test) COMPREPLY=($(compgen -W "$test_options" -- "$cur")) ;;
    audit) COMPREPLY=($(compgen -W "$audit_options" -- "$cur")) ;;
    release)
      if [[ $cword -eq 2 ]]; then
        COMPREPLY=($(compgen -W "$release_subcommands $release_options" -- "$cur"))
      elif [[ "$secondary" == "prepare" || "$secondary" == "publish" ]]; then
        COMPREPLY=($(compgen -W "$release_options" -- "$cur"))
      else
        COMPREPLY=($(compgen -W "$release_options" -- "$cur"))
      fi
      ;;
    help) COMPREPLY=($(compgen -W "$commands" -- "$cur")) ;;
  esac
}

complete -F _kite_completion kite
COMPEOF
}

run_completion() {
  local shell_type="${1:-bash}"
  case "$shell_type" in
    bash) emit_bash_completion ;;
    *) echo "Unsupported shell: $shell_type (only bash is supported)" >&2; return 1 ;;
  esac
}


run_install_action() {
  local -a installer_args=(--with-speckit --speckit-only)

  if [[ $force_speckit_init -eq 1 ]]; then
    installer_args+=(--force-speckit-init)
  fi

  if [[ -n "$speckit_version" ]]; then
    installer_args+=(--speckit-version "$speckit_version")
  fi

  installer_args+=(--repo "$repo" --ref "$ref" "$target_dir")

  if [[ -n "$source_dir" ]]; then
    installer_args=("${installer_args[@]:0:${#installer_args[@]}-5}" --source-dir "$source_dir" "$target_dir")
    bash "$source_dir/install.sh" "${installer_args[@]}"
    return
  fi

  require_command curl
  curl -fsSL "https://raw.githubusercontent.com/${repo}/${ref}/install.sh" | bash -s -- "${installer_args[@]}"
}

run_update_action() {
  local -a installer_args=()

  if [[ $merge_mode -ne 1 ]]; then
    installer_args+=(--force)
  fi

  if [[ $dry_run -eq 1 ]]; then
    installer_args+=(--dry-run)
  fi
  if [[ $with_speckit -eq 1 ]]; then
    installer_args+=(--with-speckit)
  fi
  if [[ $force_speckit_init -eq 1 ]]; then
    installer_args+=(--force-speckit-init)
  fi
  if [[ -n "$speckit_version" ]]; then
    installer_args+=(--speckit-version "$speckit_version")
  fi

  installer_args+=(--repo "$repo" --ref "$ref" "$target_dir")

  if [[ -n "$source_dir" ]]; then
    installer_args=("${installer_args[@]:0:${#installer_args[@]}-5}" --source-dir "$source_dir" "$target_dir")
    bash "$source_dir/install.sh" "${installer_args[@]}"
    return
  fi

  require_command curl
  curl -fsSL "https://raw.githubusercontent.com/${repo}/${ref}/install.sh" | bash -s -- "${installer_args[@]}"
}

run_status() {
  local resolved_source speckit_state asset workspace_status speckit_status preset_state workflow_state source_label

  resolved_source="$(resolve_source_root)"
  collect_asset_state "$resolved_source"

  if has_speckit_bootstrap "$target_dir"; then
    speckit_state="bootstrapped"
  elif [[ -d "$target_dir/.specify" ]]; then
    speckit_state="partial"
  else
    speckit_state="missing"
  fi

  if (( ${#ASSET_MISSING[@]} == 0 && ${#ASSET_OUTDATED[@]} == 0 )); then
    workspace_status="current"
  else
    workspace_status="needs-refresh"
  fi

  if [[ "$speckit_state" == "bootstrapped" ]]; then
    speckit_status="ready"
    preset_state="installed"
    workflow_state="installed"
  elif [[ "$speckit_state" == "partial" ]]; then
    speckit_status="action-needed"
    preset_state="incomplete"
    workflow_state="incomplete"
  else
    speckit_status="action-needed"
    preset_state="missing"
    workflow_state="missing"
  fi

  if [[ -n "$source_dir" ]]; then
    source_label="$resolved_source"
  else
    source_label="${repo}@${ref}"
  fi

  # Read installed version stamp
  local installed_ref="" installed_sha="" installed_date=""
  if [[ -f "$target_dir/.dev-env-version" ]]; then
    installed_ref="$(grep '^ref=' "$target_dir/.dev-env-version" 2>/dev/null | cut -d= -f2- || true)"
    installed_sha="$(grep '^sha=' "$target_dir/.dev-env-version" 2>/dev/null | cut -d= -f2- || true)"
    installed_date="$(grep '^date=' "$target_dir/.dev-env-version" 2>/dev/null | cut -d= -f2- || true)"
  fi

  if [[ $status_json -eq 1 ]]; then
    printf '{'
    printf '"target":'
    json_escape "$target_dir"
    printf ','
    printf '"source":'
    json_escape "$source_label"
    printf ','
    printf '"assets":{'
    printf '"current":'
    json_array "${ASSET_CURRENT[@]}"
    printf ','
    printf '"missing":'
    json_array "${ASSET_MISSING[@]}"
    printf ','
    printf '"outdated":'
    json_array "${ASSET_OUTDATED[@]}"
    printf '},'
    printf '"workspaceStatus":'
    json_escape "$workspace_status"
    printf ','
    printf '"speckit":{'
    printf '"state":'
    json_escape "$speckit_state"
    printf ','
    printf '"preset":'
    json_escape "$preset_state"
    printf ','
    printf '"workflow":'
    json_escape "$workflow_state"
    printf ','
    printf '"status":'
    json_escape "$speckit_status"
    printf '}'
    if [[ -n "$installed_ref" ]]; then
      printf ','
      printf '"installedVersion":{'
      printf '"ref":'
      json_escape "${installed_ref}"
      printf ','
      printf '"sha":'
      json_escape "${installed_sha:-unknown}"
      printf ','
      printf '"date":'
      json_escape "${installed_date:-unknown}"
      printf '}'
    fi
    printf '}\n'
    return
  fi

  echo "Target: $target_dir"
  echo "Source: $source_label"

  if [[ -n "$installed_ref" ]]; then
    echo ""
    echo "Installed version:"
    echo "  ref:  ${installed_ref}"
    echo "  sha:  ${installed_sha:-unknown}"
    echo "  date: ${installed_date:-unknown}"
  fi

  echo ""
  echo "Workspace assets:"
  for asset in "${assets[@]}"; do
    if [[ " ${ASSET_CURRENT[*]} " == *" $asset "* ]]; then
      echo "  current  $asset"
    elif [[ " ${ASSET_OUTDATED[*]} " == *" $asset "* ]]; then
      echo "  outdated $asset"
    else
      echo "  missing  $asset"
    fi
  done
  echo ""
  echo "Spec Kit: $speckit_state"
  echo "  preset:   $preset_state"
  echo "  workflow: $workflow_state"
  echo ""
  echo "Workspace status: ${workspace_status//-/ }"
  echo "Speckit status: ${speckit_status//-/ }"
}

run_doctor() {
  local resolved_source issues=0 speckit_fix

  resolved_source="$(resolve_source_root)"
  collect_asset_state "$resolved_source"

  echo "Doctor target: $target_dir"

  if command -v uv >/dev/null 2>&1; then
    echo "[ok] uv is available"
  else
    echo "[warn] uv is missing"
    echo "       Fix: $(build_post_create_command)"
    issues=1
  fi

  if command -v uvx >/dev/null 2>&1 || command -v specify >/dev/null 2>&1; then
    echo "[ok] Spec Kit runtime is available (uvx or specify)"
  else
    echo "[warn] neither uvx nor specify is available"
    echo "       Fix: $(build_post_create_command)"
    issues=1
  fi

  if (( ${#ASSET_MISSING[@]} == 0 && ${#ASSET_OUTDATED[@]} == 0 )); then
    echo "[ok] workspace assets are current"
  else
    if (( ${#ASSET_MISSING[@]} > 0 )); then
      echo "[warn] workspace assets are missing: ${ASSET_MISSING[*]}"
    fi
    if (( ${#ASSET_OUTDATED[@]} > 0 )); then
      echo "[warn] workspace assets are outdated: ${ASSET_OUTDATED[*]}"
    fi
    echo "       Fix: $(build_kite_command update workspace)"
    issues=1
  fi

  if [[ -f "$target_dir/.dev-env-version" ]]; then
    echo "[ok] workspace version stamp present"
  else
    echo "[info] no workspace version stamp found (run kite update workspace to add one)"
  fi

  if has_speckit_bootstrap "$target_dir"; then
    echo "[ok] bundled Spec Kit preset, commands, workflow, and agents are installed"
  elif [[ -d "$target_dir/.specify" ]]; then
    speckit_fix="$(build_kite_command install speckit --force-speckit-init)"
    echo "[warn] .specify exists, but the bundled Spec Kit preset/workflow is incomplete"
    echo "       Fix: $speckit_fix"
    issues=1
  else
    speckit_fix="$(build_kite_command install speckit)"
    echo "[warn] bundled Spec Kit is not bootstrapped"
    echo "       Fix: $speckit_fix"
    issues=1
  fi

  if [[ $issues -eq 0 ]]; then
    echo "Doctor status: ready"
    return 0
  fi

  echo "Doctor status: action needed"
  return 1
}

normalize_target_dir() {
  if ! target_dir="$(cd -- "$target_dir" 2>/dev/null && pwd)"; then
    echo "Target directory does not exist." >&2
    exit 1
  fi
}

parse_help_target() {
  local first="${1:-}"
  local second="${2:-}"
  local target="$first"

  if [[ -n "$second" ]]; then
    target+=" $second"
  fi

  case "$target" in
    "install speckit")
      show_help "install-speckit"
      ;;
    "update workspace")
      show_help "update-workspace"
      ;;
    "doctor")
      show_help "doctor"
      ;;
    "status")
      show_help "status"
      ;;
    "test")
      show_help "test"
      ;;
    "audit")
      show_help "audit"
      ;;
    "release"|"release prepare"|"release publish")
      show_help "release"
      ;;
    "verify feature")
      show_help "verify-feature"
      ;;
    "feature")
      show_help "feature"
      ;;
    "explain")
      show_help "explain"
      ;;
    *)
      show_help "general"
      ;;
  esac
}

main() {
  local primary_command="${1:-}"
  local secondary_command="${2:-}"

  if [[ -z "$primary_command" || "$primary_command" == "-h" || "$primary_command" == "--help" ]]; then
    show_help "general"
    exit 0
  fi

  if [[ "$primary_command" == "help" ]]; then
    parse_help_target "$secondary_command" "${3:-}"
    exit 0
  fi

  if [[ "$primary_command" == "speckit" && "$secondary_command" == "install" ]]; then
    primary_command="install"
    secondary_command="speckit"
  fi

  case "$primary_command" in
    install)
      if [[ "$secondary_command" != "speckit" ]]; then
        echo "Unknown command: ${primary_command} ${secondary_command}" >&2
        show_help "general" >&2
        exit 1
      fi
      mode="install-speckit"
      shift 2
      ;;
    update)
      if [[ "$secondary_command" != "workspace" ]]; then
        echo "Unknown command: ${primary_command} ${secondary_command}" >&2
        show_help "general" >&2
        exit 1
      fi
      mode="update-workspace"
      shift 2
      ;;
    doctor)
      mode="doctor"
      shift 1
      ;;
    status)
      mode="status"
      shift 1
      ;;
    test|audit|release)
      mode="$primary_command"
      shift 1
      ;;
    verify)
      if [[ "$secondary_command" != "feature" ]]; then
        echo "Unknown command: ${primary_command} ${secondary_command}" >&2
        show_help "general" >&2
        exit 1
      fi
      mode="verify-feature"
      shift 2
      ;;
    feature)
      mode="feature"
      shift 1
      ;;
    explain)
      mode="explain"
      shift 1
      ;;
    completion)
      mode="completion"
      shift 1
      ;;
    *)
      echo "Unknown command: ${primary_command} ${secondary_command}" >&2
      show_help "general" >&2
      exit 1
      ;;
  esac

  # Commands that handle their own argument parsing
  if [[ "$mode" == "test" || "$mode" == "audit" || "$mode" == "release" || "$mode" == "verify-feature" ]]; then
    local -a passthrough_args=()
    local arg
    for arg in "$@"; do
      if [[ "$arg" != -* ]] && [[ -d "$arg" ]] && [[ -z "$target_dir" || "$target_dir" == "." ]]; then
        target_dir="$arg"
      else
        passthrough_args+=("$arg")
      fi
    done
    normalize_target_dir

    case "$mode" in
      test)    run_test "${passthrough_args[@]+"${passthrough_args[@]}"}" ;;
      audit)   run_audit "${passthrough_args[@]+"${passthrough_args[@]}"}" ;;
      release) run_release "${passthrough_args[@]+"${passthrough_args[@]}"}" ;;
      verify-feature) run_verify_feature ;;
    esac
    exit $?
  fi

  # Handle completion mode
  if [[ "$mode" == "completion" ]]; then
    run_completion "${1:-bash}"
    exit $?
  fi

  # Handle explain mode (takes a single stage arg, no target-dir)
  if [[ "$mode" == "explain" ]]; then
    run_explain "$@"
    exit $?
  fi

  # Handle feature mode (optional target-dir and --json)
  if [[ "$mode" == "feature" ]]; then
    local feature_json=0
    local -a feature_rest=()
    local farg
    for farg in "$@"; do
      case "$farg" in
        --json) feature_json=1 ;;
        -h|--help) show_help "feature"; exit 0 ;;
        -*) echo "Unknown option: $farg" >&2; show_help "feature" >&2; exit 1 ;;
        *) feature_rest+=("$farg") ;;
      esac
    done
    if [[ ${#feature_rest[@]} -gt 1 ]]; then
      echo "Unexpected arguments: ${feature_rest[*]:1}" >&2
      show_help "feature" >&2
      exit 1
    fi
    if [[ ${#feature_rest[@]} -eq 1 ]]; then
      target_dir="${feature_rest[0]}"
    fi
    normalize_target_dir
    run_feature_status "$feature_json"
    exit $?
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        if [[ "$mode" != "update-workspace" ]]; then
          echo "Unknown option: $1" >&2
          show_help "$mode" >&2
          exit 1
        fi
        dry_run=1
        shift
        ;;
      --merge)
        if [[ "$mode" != "update-workspace" ]]; then
          echo "Unknown option: $1" >&2
          show_help "$mode" >&2
          exit 1
        fi
        merge_mode=1
        shift
        ;;
      --with-speckit)
        if [[ "$mode" != "update-workspace" ]]; then
          echo "Unknown option: $1" >&2
          show_help "$mode" >&2
          exit 1
        fi
        with_speckit=1
        shift
        ;;
      --json)
        if [[ "$mode" != "status" ]]; then
          echo "Unknown option: $1" >&2
          show_help "$mode" >&2
          exit 1
        fi
        status_json=1
        shift
        ;;
      --force-speckit-init)
        if [[ "$mode" != "install-speckit" && "$mode" != "update-workspace" ]]; then
          echo "Unknown option: $1" >&2
          show_help "$mode" >&2
          exit 1
        fi
        force_speckit_init=1
        shift
        ;;
      --speckit-version)
        speckit_version="${2:?Missing value for --speckit-version}"
        shift 2
        ;;
      --repo)
        repo="${2:?Missing value for --repo}"
        shift 2
        ;;
      --ref)
        ref="${2:?Missing value for --ref}"
        shift 2
        ;;
      --source-dir)
        source_dir="${2:?Missing value for --source-dir}"
        shift 2
        ;;
      -h|--help)
        show_help "$mode"
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -* )
        echo "Unknown option: $1" >&2
        show_help "$mode" >&2
        exit 1
        ;;
      *)
        target_dir="$1"
        shift
        ;;
    esac
  done

  if [[ $# -gt 0 ]]; then
    echo "Unexpected arguments: $*" >&2
    show_help "$mode" >&2
    exit 1
  fi

  normalize_target_dir

  case "$mode" in
    install-speckit)
      run_install_action
      ;;
    update-workspace)
      run_update_action
      ;;
    doctor)
      run_doctor
      ;;
    status)
      run_status
      ;;
  esac
}

main "$@"